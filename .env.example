# docker compose reads this root .env file.
# For backend local dev, copy this to backend/.env and adjust as needed.
# NEVER commit the real .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# FRONTEND_DIR: carpeta del build del frontend que el backend sirve (modo "un
# solo enlace"). En Docker se define automáticamente (/app/public); NO la pongas
# aquí para dev local (en dev Vite sirve el frontend en el puerto 5173).
# FRONTEND_DIR=/app/public

# ── Database ─────────────────────────────────────────────────────────────────
# External/remote PostgreSQL — replace with your actual connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/oriental

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_at_least_16_chars      # Use a long random string in production

# ── WhatsApp chatbot search API ──────────────────────────────────────────────
SEARCH_API_KEY=change_me_8chars             # Sent in header x-api-key by the bot

# ── Admin seed account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@oriental.local
ADMIN_PASSWORD=admin1234                    # Change immediately after first login
ADMIN_NOMBRE=Administrador

# ── CORS / Cookies ───────────────────────────────────────────────────────────
# En modo "un solo enlace" el frontend y la API comparten origen, así que CORS
# no interviene; déjalo en tu dominio público de todos modos.
CORS_ORIGIN=http://localhost                # Tu dominio público en producción
COOKIE_SECURE=false                         # true cuando corras detrás de HTTPS (EasyPanel)

# ── Business margins ─────────────────────────────────────────────────────────
MARGIN_UTILIDAD=1.2
MARGIN_FACTOR=1.33333

# ── Migrations ───────────────────────────────────────────────────────────────
RUN_MIGRATIONS=true                         # Set to false after first successful run if desired
